# 이 파일을 .env로 복사 후 실제 값 채우기. .env는 gitignored — 절대 커밋 X.

# Server bind
PORT=4000
HOST=0.0.0.0

# CORS: 콤마(,)로 구분 여러 origin 허용. production은 Vercel URL.
# 예: "https://gostop.vercel.app,https://gostop-preview.vercel.app"
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# LiveKit Cloud (https://cloud.livekit.io 가입 후 project 만들면 발급)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# 로깅 모드 — production이면 pino-pretty 비활성, JSON 로그.
# Railway 배포 시 NODE_ENV=production 자동 주입.
NODE_ENV=development
