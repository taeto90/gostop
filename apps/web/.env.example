# 이 파일을 .env로 복사 후 실제 값 채우기. .env는 gitignored.

# server URL — production은 Railway 배포 URL.
# 예: "https://gostopserver-production.up.railway.app"
VITE_SERVER_URL=http://localhost:4000

# Supabase — 게임 히스토리 cross-device sync. 미설정 시 localStorage만 사용.
# Project URL: https://xxxxx.supabase.co (끝에 / 또는 /rest/v1/ 빼기)
VITE_SUPABASE_URL=
# anon public key — JWT (eyJ...) 형식. service_role 절대 X.
VITE_SUPABASE_ANON_KEY=
